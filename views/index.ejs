<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Quantum Color Circuit Simulator</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #0e0e0e; color: #ddd;
    font-family: "SF Mono", "Courier New", monospace;
    padding: 28px; min-height: 100vh;
  }
  h1 { font-size: 1rem; font-weight: 500; letter-spacing: .12em; color: #888; margin-bottom: 20px; text-transform: uppercase; }
  h2 { font-size: .8rem; font-weight: 500; color: #666; letter-spacing: .1em; margin: 24px 0 12px; text-transform: uppercase; }

  #palette {
    display: flex; gap: 6px; flex-wrap: wrap; align-items: center;
    padding: 10px 12px; background: #161616; border: 1px solid #262626; border-radius: 4px;
    margin-bottom: 16px;
  }
  #palette .label { font-size: .65rem; color: #555; letter-spacing: .1em; margin-right: 6px; }

  .palette-gate {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: #212121; border: 1px solid #3a3a3a; border-radius: 3px;
    cursor: grab; user-select: none; font-size: .85rem;
    transition: border-color .15s, background .15s;
  }
  .palette-gate:hover { border-color: #666; background: #2a2a2a; }
  .palette-gate:active { cursor: grabbing; }
  .palette-gate.rotation { border-color: #3a3a5a; }
  .palette-gate.cnot { border-color: #3a5a3a; }
  .palette-gate.measure { border-color: #6a4a8a; }

  #controls { display: flex; gap: 8px; align-items: center; }
  .left-col { display: flex; flex-direction: column; gap: 16px; }
  button { font-family: inherit; font-size: .8rem; letter-spacing: .05em; cursor: pointer; }
  #compute-btn {
    padding: 8px 18px; background: #1a3a1a; border: 1px solid #4a7a4a; color: #9cc;
    border-radius: 3px; color: #8cba8c;
  }
  #compute-btn:hover { background: #234523; border-color: #6a9a6a; }
  #clear-btn {
    padding: 8px 14px; background: #1a1a1a; border: 1px solid #3a3a3a; color: #888; border-radius: 3px;
  }
  #clear-btn:hover { border-color: #555; color: #ccc; }
  #status { font-size: .7rem; color: #666; margin-left: 8px; }

  #circuit-container { position: relative; display: inline-block; }
  .top-row { display: flex; gap: 28px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 24px; }
  .result-row { display: flex; align-items: flex-start; gap: 20px; flex-wrap: wrap; }

  #prob-panel {
    background: #161616; border: 1px solid #262626; border-radius: 4px;
    padding: 12px 14px; min-width: 180px; max-width: 220px;
    font-size: .72rem;
  }
  #prob-panel.empty { display: none; }
  .panel-title { font-size: .62rem; color: #777; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 12px; }
  .prob-entry + .prob-entry { margin-top: 10px; padding-top: 10px; border-top: 1px solid #222; }
  .prob-header { font-size: .7rem; color: #aaa; margin-bottom: 6px; display: flex; justify-content: space-between; }
  .prob-header .pos { font-size: .6rem; color: #555; }
  .prob-row { display: grid; grid-template-columns: 20px 1fr 38px; align-items: center; gap: 6px; margin-bottom: 3px; }
  .prob-row .state { color: #888; font-size: .7rem; }
  .prob-row .bar { height: 6px; background: #0a0a0a; border-radius: 2px; overflow: hidden; }
  .prob-row .fill { height: 100%; background: #7a5a9a; border-radius: 2px; transition: width .2s; }
  .prob-row .value { font-size: .65rem; text-align: right; color: #aaa; }
  #circuit-grid {
    display: grid;
    grid-template-columns: 36px repeat(8, 68px);
    grid-auto-rows: 56px;
    background: #161616; border: 1px solid #262626; border-radius: 4px; padding: 8px;
  }
  .qubit-label {
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; color: #777;
  }
  .gate-slot {
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .gate-slot::before {
    content: ''; position: absolute; left: 0; right: 0; top: 50%;
    height: 2px; background: #333; z-index: 0;
  }
  .gate-slot.drag-over { background: rgba(255,255,255,.04); }
  .gate-slot.pending-target { cursor: pointer; }
  .gate-slot.pending-target::after {
    content: ''; position: absolute; inset: 6px;
    border: 1px dashed #4a7a4a; border-radius: 3px;
    animation: pulse 1.2s infinite;
  }
  @keyframes pulse { 0%,100% { opacity: .4; } 50% { opacity: 1; } }

  #cnot-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }

  .placed-gate {
    position: relative; z-index: 2; cursor: pointer; user-select: none;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 40px; height: 40px; background: #222; border: 1px solid #555; border-radius: 3px;
    font-size: .8rem;
  }
  .placed-gate.rotation { border-color: #5a5a7a; height: 40px; }
  .placed-gate .angle { font-size: .55rem; color: #999; margin-top: 1px; }
  .placed-gate:hover { border-color: #a55; }
  .placed-gate:hover::after {
    content: '×'; position: absolute; top: -7px; right: -7px;
    width: 14px; height: 14px; border-radius: 50%;
    background: #5a1a1a; color: #eaa; font-size: .6rem;
    display: flex; align-items: center; justify-content: center;
  }
  .placed-gate.cnot-control {
    width: 16px; height: 16px; border-radius: 50%;
    background: #4a7a4a; border-color: #4a7a4a;
  }
  .placed-gate.cnot-target {
    width: 28px; height: 28px; border-radius: 50%;
    background: transparent; border: 1.5px solid #4a7a4a;
    font-size: 1rem; color: #8cba8c;
  }
  .placed-gate.measure { border-color: #6a4a8a; background: #1e1824; color: #b89acc; }
  .placed-gate.pending {
    background: rgba(74,122,74,.3);
  }

  #color-section { display: none; }
  #color-canvas { display: block; background: #0a0a0a; border: 1px solid #222; border-radius: 4px; }

  #about { flex: 1 1 340px; max-width: 540px; }
  #about h2 { font-size: .78rem; font-weight: 500; color: #777; letter-spacing: .12em; text-transform: uppercase; margin: 0 0 10px 0; }
  .about-body { display: flex; gap: 14px; align-items: flex-start; flex-wrap: wrap; }
  .about-body .about-text { flex: 1 1 170px; min-width: 0; }
  .about-right { flex: 0 0 auto; display: flex; flex-direction: column; gap: 6px; }
  .about-diagram svg { display: block; }
  .about-axes { list-style: none; padding: 0; margin: 0; font-size: .68rem; line-height: 1.55; color: #bbb; }
  .about-axes li { margin-bottom: 3px; padding-left: 12px; position: relative; }
  .about-axes li::before { content: '·'; position: absolute; left: 4px; color: #555; }
  .about-axes code { background: #181818; padding: 0 4px; border-radius: 2px; font-size: .68rem; color: #d0d0d0; }
  .about-text { font-size: .72rem; line-height: 1.5; color: #bbb; }
  .about-text p { margin-bottom: 8px; }
  .about-text code { background: #181818; padding: 0 4px; border-radius: 2px; font-size: .72rem; color: #d0d0d0; }
  .credit {
    margin-top: 14px; font-size: .7rem; color: #666; letter-spacing: .04em;
    padding-top: 12px; border-top: 1px dashed #222;
  }
  .credit strong { color: #aaa; font-weight: 500; }
  .axis-L { color: #e0e0e0; }
  .axis-a { color: #ff6a8e; }
  .axis-b { color: #e0c065; }

  .touch-ghost {
    position: fixed; z-index: 1000; pointer-events: none;
    width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
    background: rgba(34,34,34,.92); border: 1px solid #666; border-radius: 3px;
    color: #ddd; font-size: .8rem; font-family: inherit;
  }

  @media (max-width: 768px) {
    body { padding: 16px; }
    h1 { font-size: .85rem; margin-bottom: 14px; }
    .top-row { flex-direction: column; gap: 20px; }
    #about { max-width: 100%; }
    .about-body { flex-direction: column; }
    .about-right { align-items: center; }
    #circuit-container { overflow-x: auto; -webkit-overflow-scrolling: touch; max-width: 100%; }
    #circuit-grid {
      grid-template-columns: 28px repeat(8, 52px);
      grid-auto-rows: 46px;
      padding: 6px;
    }
    .placed-gate { width: 34px; height: 34px; font-size: .72rem; }
    .placed-gate .angle { font-size: .48rem; }
    .placed-gate.cnot-target { width: 24px; height: 24px; font-size: .85rem; }
    .palette-gate { width: 38px; height: 38px; font-size: .78rem; }
    #palette { gap: 5px; padding: 8px 10px; }
    #palette .label { font-size: .6rem; }
    #controls { flex-wrap: wrap; }
    #compute-btn { font-size: .75rem; padding: 7px 14px; }
    #clear-btn { font-size: .75rem; padding: 7px 12px; }
    .result-row { flex-direction: column; }
    #prob-panel { max-width: 100%; }
    #color-section { overflow-x: auto; }
    .credit { font-size: .65rem; }
  }

  @media (max-width: 420px) {
    body { padding: 12px; }
    #circuit-grid {
      grid-template-columns: 22px repeat(8, 42px);
      grid-auto-rows: 40px;
    }
    .placed-gate { width: 28px; height: 28px; font-size: .62rem; }
    .placed-gate.cnot-control { width: 14px; height: 14px; }
    .placed-gate.cnot-target { width: 22px; height: 22px; font-size: .75rem; }
    .palette-gate { width: 34px; height: 34px; font-size: .72rem; }
  }

  #angle-modal {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7);
    align-items: center; justify-content: center; z-index: 100;
  }
  #angle-modal.visible { display: flex; }
  .modal-card {
    background: #181818; border: 1px solid #333; border-radius: 5px; padding: 22px;
    min-width: 280px;
  }
  .modal-card h3 { font-size: .85rem; font-weight: 500; color: #aaa; margin-bottom: 14px; letter-spacing: .08em; }
  .angle-presets { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 12px; }
  .preset-btn {
    padding: 4px 10px; background: #222; border: 1px solid #3a3a3a;
    color: #bbb; border-radius: 3px; font-size: .75rem;
  }
  .preset-btn:hover { border-color: #666; }
  .modal-row { display: flex; gap: 6px; margin-top: 14px; }
  #angle-input {
    flex: 1; background: #0a0a0a; border: 1px solid #333; color: #ddd;
    padding: 6px 10px; border-radius: 3px; font-family: inherit; font-size: .85rem;
  }
  #angle-ok { padding: 6px 14px; background: #1a3a1a; border: 1px solid #4a7a4a; color: #9c9; border-radius: 3px; }
  #angle-cancel { padding: 6px 14px; background: #1a1a1a; border: 1px solid #3a3a3a; color: #999; border-radius: 3px; }
</style>
</head>
<body>
  <h1>Quantum Color Circuit Simulator</h1>

  <div id="palette">
    <span class="label">GATES</span>
    <div class="palette-gate" draggable="true" data-gate="h">H</div>
    <div class="palette-gate" draggable="true" data-gate="x">X</div>
    <div class="palette-gate" draggable="true" data-gate="y">Y</div>
    <div class="palette-gate" draggable="true" data-gate="z">Z</div>
    <div class="palette-gate" draggable="true" data-gate="s">S</div>
    <div class="palette-gate" draggable="true" data-gate="t">T</div>
    <div class="palette-gate rotation" draggable="true" data-gate="rx">Rx</div>
    <div class="palette-gate rotation" draggable="true" data-gate="ry">Ry</div>
    <div class="palette-gate rotation" draggable="true" data-gate="rz">Rz</div>
    <div class="palette-gate cnot" draggable="true" data-gate="cx">CNOT</div>
    <div class="palette-gate measure" draggable="true" data-gate="measure">M</div>
  </div>

  <div class="top-row">
    <div class="left-col">
      <div id="controls">
        <button id="compute-btn">Compute Color Map</button>
        <button id="clear-btn">Clear</button>
        <span id="status"></span>
      </div>
      <div id="circuit-container">
        <div id="circuit-grid"></div>
        <svg id="cnot-overlay"></svg>
      </div>
    </div>

    <section id="about">
      <h2>The Color Map at a Glance</h2>
      <div class="about-body">
        <div class="about-text">
          <p>
            The wire colors let you visualize how much a qubit "knows" about its own
            state. Black or white means definite; a neutral mid-gray signals maximum
            entropy — often the signature of entanglement with another qubit.
          </p>
          <p>
            Under the hood, each wire color is the qubit's reduced Bloch vector
            <code>(⟨X⟩, ⟨Y⟩, ⟨Z⟩)</code> mapped through the CIELAB color solid.
            <span class="axis-L">L*</span> tracks <code>⟨Z⟩</code> (computational-basis
            bias), while <span class="axis-a">a*</span> and
            <span class="axis-b">b*</span> track the off-diagonal coherences
            <code>⟨X⟩</code> and <code>⟨Y⟩</code> — so saturation reflects quantum purity,
            and hue encodes the phase of the superposition.
          </p>
        </div>

        <div class="about-right">
          <div class="about-diagram">
            <svg viewBox="0 0 280 320" width="160" height="183" aria-label="Bloch sphere with colored cardinal states">
              <circle cx="140" cy="160" r="100" fill="none" stroke="#333" stroke-width="1"/>
              <ellipse cx="140" cy="160" rx="100" ry="26" fill="none" stroke="#2a2a2a" stroke-width="0.7" stroke-dasharray="2 3"/>
              <ellipse cx="140" cy="160" rx="26" ry="100" fill="none" stroke="#2a2a2a" stroke-width="0.7" stroke-dasharray="2 3"/>
              <line x1="140" y1="55" x2="140" y2="265" stroke="#3a3a3a" stroke-width="0.6"/>
              <line x1="35" y1="160" x2="245" y2="160" stroke="#3a3a3a" stroke-width="0.6"/>

              <text x="252" y="164" fill="#666" font-size="10" font-style="italic">X</text>
              <text x="144" y="52" fill="#666" font-size="10" font-style="italic">Z</text>
              <text x="162" y="198" fill="#666" font-size="10" font-style="italic">Y</text>

              <circle cx="140" cy="60" r="10" fill="rgb(0,0,0)" stroke="#aaa" stroke-width="1"/>
              <text x="140" y="30" text-anchor="middle" fill="#ccc" font-size="13" font-family="monospace">|0⟩</text>

              <circle cx="140" cy="260" r="10" fill="rgb(255,254,254)" stroke="#888" stroke-width="1"/>
              <text x="140" y="305" text-anchor="middle" fill="#ccc" font-size="13" font-family="monospace">|1⟩</text>

              <circle cx="240" cy="160" r="10" fill="rgb(255,0,112)" stroke="#aaa" stroke-width="1"/>
              <text x="262" y="164" fill="#ccc" font-size="13" font-family="monospace">|+⟩</text>

              <circle cx="40" cy="160" r="10" fill="rgb(0,155,115)" stroke="#aaa" stroke-width="1"/>
              <text x="18" y="164" text-anchor="end" fill="#ccc" font-size="13" font-family="monospace">|−⟩</text>

              <circle cx="140" cy="186" r="10" fill="rgb(141,117,0)" stroke="#aaa" stroke-width="1"/>
              <text x="156" y="192" fill="#ccc" font-size="13" font-family="monospace">|+i⟩</text>

              <circle cx="140" cy="134" r="10" fill="rgb(0,96,255)" stroke="#aaa" stroke-width="1"/>
              <text x="156" y="128" fill="#ccc" font-size="13" font-family="monospace">|−i⟩</text>

              <circle cx="140" cy="160" r="6" fill="rgb(118,118,118)" stroke="#555" stroke-width="0.8"/>
            </svg>
          </div>
          <ul class="about-axes">
            <li><span class="axis-L">L*</span> ← <code>⟨Z⟩</code>: |0⟩→black, |1⟩→white</li>
            <li><span class="axis-a">a*</span> ← <code>⟨X⟩</code>: |−⟩→green, |+⟩→red</li>
            <li><span class="axis-b">b*</span> ← <code>⟨Y⟩</code>: |−i⟩→blue, |+i⟩→yellow</li>
          </ul>
        </div>
      </div>

      <div class="credit">
        Color-to-Bloch-sphere mapping due to <strong>J. P. Marceaux</strong> (UC Berkeley PhD).
      </div>
    </section>
  </div>

  <div id="color-section">
    <h2>Result</h2>
    <div class="result-row">
      <canvas id="color-canvas"></canvas>
      <div id="prob-panel" class="empty"></div>
    </div>
  </div>


  <div id="angle-modal">
    <div class="modal-card">
      <h3 id="angle-title">Rotation Angle</h3>
      <div class="angle-presets">
        <button class="preset-btn" data-val="1.5708">π/2</button>
        <button class="preset-btn" data-val="-1.5708">-π/2</button>
        <button class="preset-btn" data-val="3.14159">π</button>
        <button class="preset-btn" data-val="0.7854">π/4</button>
        <button class="preset-btn" data-val="1.0472">π/3</button>
        <button class="preset-btn" data-val="0.5236">π/6</button>
      </div>
      <div class="modal-row">
        <input type="number" id="angle-input" value="1.5708" step="0.01">
        <button id="angle-ok">OK</button>
        <button id="angle-cancel">Cancel</button>
      </div>
    </div>
  </div>

<script>
  const NUM_QUBITS = 4;
  const NUM_COLS = 8;
  const GATE_NAMES = { h:'H', x:'X', y:'Y', z:'Z', s:'S', t:'T', rx:'Rx', ry:'Ry', rz:'Rz', measure:'M' };
  const ROTATIONS = new Set(['rx', 'ry', 'rz']);

  let circuit = [];
  let pendingCNOT = null;
  let pendingAngle = null;
  let dragGate = null;      // palette drag: gate name string
  let dragPlaced = null;    // placed-gate drag: { gateRef, role }
  let lastResult = null;

  // Touch drag state
  let touchDrag = null;     // { source, gate/gateRef/role, label }
  let touchGhost = null;
  let touchMoved = false;
  let suppressClick = false;

  // ---------- build grid ----------
  const grid = document.getElementById('circuit-grid');
  for (let q = 0; q < NUM_QUBITS; q++) {
    const label = document.createElement('div');
    label.className = 'qubit-label';
    label.textContent = `q${q}`;
    grid.appendChild(label);

    for (let c = 0; c < NUM_COLS; c++) {
      const slot = document.createElement('div');
      slot.className = 'gate-slot';
      slot.dataset.col = c;
      slot.dataset.qubit = q;
      slot.addEventListener('dragover', onDragOver);
      slot.addEventListener('dragleave', onDragLeave);
      slot.addEventListener('drop', onDrop);
      slot.addEventListener('click', onSlotClick);
      grid.appendChild(slot);
    }
  }

  document.querySelectorAll('.palette-gate').forEach(el => {
    el.addEventListener('dragstart', e => {
      dragGate = el.dataset.gate;
      dragPlaced = null;
      e.dataTransfer.effectAllowed = 'copy';
      e.dataTransfer.setData('text/plain', dragGate);
    });
    el.addEventListener('dragend', () => { dragGate = null; });
    // Touch support
    el.addEventListener('touchstart', () => {
      touchDrag = { source: 'palette', gate: el.dataset.gate, label: el.textContent.trim() };
      touchMoved = false;
    }, { passive: true });
  });

  function onDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'copy';
    this.classList.add('drag-over');
  }
  function onDragLeave() { this.classList.remove('drag-over'); }

  function lastGateCol(qubit) {
    let mx = -1;
    for (const g of circuit) {
      const onThis = g.gate === 'cx' ? (g.control === qubit || g.target === qubit) : (g.qubit === qubit);
      if (onThis && g.col > mx) mx = g.col;
    }
    return mx;
  }

  function globalDefaultCol() {
    let mx = -1;
    for (let q = 0; q < NUM_QUBITS; q++) mx = Math.max(mx, lastGateCol(q));
    return mx + 1;
  }

  function resolveDropCol(targetCol, qubits) {
    const def = globalDefaultCol();
    if (targetCol < def) {
      for (const q of qubits) if (gateAt(targetCol, q)) return def;
      return targetCol;  // manual placement to the left of the global default is allowed
    }
    return def;  // drops at or past the default snap back
  }

  function movePlacedGate(state, dropCol, dropQubit) {
    const g = state.gateRef;
    const idx = circuit.indexOf(g);
    if (idx < 0) return;
    // Remove the gate first so auto-drop logic sees the cell it came from as free
    circuit.splice(idx, 1);

    let newEntry;
    if (g.gate === 'cx') {
      const otherQubit = state.role === 'control' ? g.target : g.control;
      if (otherQubit === dropQubit) {
        circuit.splice(idx, 0, g);
        setStatus('Control and target must differ.');
        return;
      }
      const newControl = state.role === 'control' ? dropQubit : g.control;
      const newTarget = state.role === 'target' ? dropQubit : g.target;
      const finalCol = resolveDropCol(dropCol, [newControl, newTarget]);
      if (finalCol >= NUM_COLS) {
        circuit.splice(idx, 0, g);
        setStatus('No room.');
        return;
      }
      newEntry = { col: finalCol, gate: 'cx', control: newControl, target: newTarget };
    } else {
      const finalCol = resolveDropCol(dropCol, [dropQubit]);
      if (finalCol >= NUM_COLS) {
        circuit.splice(idx, 0, g);
        setStatus('No room.');
        return;
      }
      newEntry = { col: finalCol, qubit: dropQubit, gate: g.gate };
      if (g.angle !== undefined) newEntry.angle = g.angle;
    }

    circuit.push(newEntry);
    setStatus('');
    render();
  }

  function attachMoveDrag(el, gateRef, role) {
    el.draggable = true;
    el.addEventListener('dragstart', (e) => {
      e.stopPropagation();
      dragPlaced = { gateRef, role };
      dragGate = null;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', 'move');
    });
    el.addEventListener('dragend', () => { dragPlaced = null; });
    // Touch support
    const label = gateRef.gate === 'cx' ? (role === 'control' ? '●' : '⊕')
      : (GATE_NAMES[gateRef.gate] || gateRef.gate);
    el.addEventListener('touchstart', () => {
      touchDrag = { source: 'placed', gateRef, role, label };
      touchMoved = false;
    }, { passive: true });
  }

  function onDrop(e) {
    e.preventDefault();
    this.classList.remove('drag-over');
    handleDrop(+this.dataset.col, +this.dataset.qubit);
  }

  function handleDrop(dropCol, qubit) {
    if (dragPlaced) {
      movePlacedGate(dragPlaced, dropCol, qubit);
      dragPlaced = null;
      return;
    }

    if (!dragGate) return;

    if (dragGate === 'cx') {
      if (pendingCNOT) cancelPendingCNOT();
      pendingCNOT = { qubit, intendedCol: dropCol };
      setStatus(`CNOT control on q${qubit}. Click any other qubit to set target.`);
      render();
    } else if (ROTATIONS.has(dragGate)) {
      const finalCol = resolveDropCol(dropCol, [qubit]);
      if (finalCol >= NUM_COLS) { setStatus('No room on this qubit.'); dragGate = null; return; }
      pendingAngle = { col: finalCol, qubit, gate: dragGate };
      showAngleModal(dragGate);
    } else {
      const finalCol = resolveDropCol(dropCol, [qubit]);
      if (finalCol >= NUM_COLS) { setStatus('No room on this qubit.'); dragGate = null; return; }
      circuit.push({ col: finalCol, qubit, gate: dragGate });
      render();
    }
    dragGate = null;
  }

  function onSlotClick() {
    if (suppressClick) return;
    const qubit = +this.dataset.qubit;
    if (!pendingCNOT) return;
    if (pendingCNOT.qubit === qubit) return;  // can't target control qubit

    const finalCol = resolveDropCol(pendingCNOT.intendedCol, [pendingCNOT.qubit, qubit]);
    if (finalCol >= NUM_COLS) { setStatus('No room for this CNOT.'); return; }

    circuit.push({ col: finalCol, gate: 'cx', control: pendingCNOT.qubit, target: qubit });
    pendingCNOT = null;
    setStatus('');
    render();
  }

  function cancelPendingCNOT() {
    pendingCNOT = null;
    setStatus('');
    render();
  }

  function gateAt(col, qubit) {
    return circuit.find(g =>
      g.col === col && (g.gate === 'cx' ? (g.control === qubit || g.target === qubit) : g.qubit === qubit)
    );
  }

  function removeGateAt(col, qubit) {
    const i = circuit.findIndex(g =>
      g.col === col && (g.gate === 'cx' ? (g.control === qubit || g.target === qubit) : g.qubit === qubit)
    );
    if (i >= 0) circuit.splice(i, 1);
    render();
  }

  // ---------- rendering ----------
  function render() {
    document.querySelectorAll('.gate-slot').forEach(s => {
      s.innerHTML = '';
      s.classList.remove('pending-target');
    });

    for (const g of circuit) {
      if (g.gate === 'cx') {
        addGateTo(g.col, g.control, makeCnotControl(g.col, g.control, g));
        addGateTo(g.col, g.target, makeCnotTarget(g.col, g.target, g));
      } else {
        addGateTo(g.col, g.qubit, makeGateEl(g));
      }
    }

    if (pendingCNOT) {
      const q1 = pendingCNOT.qubit;
      const previewCol = resolveDropCol(pendingCNOT.intendedCol, [q1]);
      if (previewCol < NUM_COLS) {
        const el = makeCnotControl(previewCol, q1);
        el.classList.add('pending');
        addGateTo(previewCol, q1, el);
      }
      // Highlight all other qubits (any column click finalizes target)
      for (let q = 0; q < NUM_QUBITS; q++) {
        if (q === q1) continue;
        const previewForPair = resolveDropCol(pendingCNOT.intendedCol, [q1, q]);
        if (previewForPair < NUM_COLS) {
          const s = slotAt(previewForPair, q);
          if (s) s.classList.add('pending-target');
        }
      }
    }

    drawCnotLines();
  }

  function addGateTo(col, qubit, el) {
    const s = slotAt(col, qubit);
    if (s) s.appendChild(el);
  }
  function slotAt(col, qubit) {
    return document.querySelector(`.gate-slot[data-col="${col}"][data-qubit="${qubit}"]`);
  }

  function makeGateEl(g) {
    const el = document.createElement('div');
    el.className = 'placed-gate';
    if (ROTATIONS.has(g.gate)) el.classList.add('rotation');
    if (g.gate === 'measure') el.classList.add('measure');
    const nameEl = document.createElement('span');
    nameEl.textContent = GATE_NAMES[g.gate];
    el.appendChild(nameEl);
    if (g.angle !== undefined) {
      const a = document.createElement('span');
      a.className = 'angle';
      a.textContent = formatAngle(g.angle);
      el.appendChild(a);
    }
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      if (suppressClick || pendingCNOT) return;
      removeGateAt(g.col, g.qubit);
    });
    attachMoveDrag(el, g, 'single');
    return el;
  }

  function makeCnotControl(col, qubit, gateRef) {
    const el = document.createElement('div');
    el.className = 'placed-gate cnot-control';
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      if (suppressClick) return;
      if (el.classList.contains('pending')) { cancelPendingCNOT(); return; }
      if (pendingCNOT) return;
      removeGateAt(col, qubit);
    });
    if (gateRef) attachMoveDrag(el, gateRef, 'control');
    return el;
  }

  function makeCnotTarget(col, qubit, gateRef) {
    const el = document.createElement('div');
    el.className = 'placed-gate cnot-target';
    el.textContent = '⊕';
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      if (suppressClick || pendingCNOT) return;
      removeGateAt(col, qubit);
    });
    if (gateRef) attachMoveDrag(el, gateRef, 'target');
    return el;
  }

  function drawCnotLines() {
    const svg = document.getElementById('cnot-overlay');
    const container = document.getElementById('circuit-container');
    svg.innerHTML = '';
    const cr = container.getBoundingClientRect();
    svg.setAttribute('width', cr.width);
    svg.setAttribute('height', cr.height);

    for (const g of circuit) {
      if (g.gate !== 'cx') continue;
      drawLine(svg, cr, g.col, g.control, g.target, '#4a7a4a');
    }
  }

  function drawLine(svg, cr, col, q1, q2, color) {
    const a = slotAt(col, q1);
    const b = slotAt(col, q2);
    if (!a || !b) return;
    const ar = a.getBoundingClientRect();
    const br = b.getBoundingClientRect();
    const x = ar.left - cr.left + ar.width / 2;
    const y1 = ar.top - cr.top + ar.height / 2;
    const y2 = br.top - cr.top + br.height / 2;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', x); line.setAttribute('y1', y1);
    line.setAttribute('x2', x); line.setAttribute('y2', y2);
    line.setAttribute('stroke', color);
    line.setAttribute('stroke-width', '1.5');
    svg.appendChild(line);
  }

  function formatAngle(a) {
    const m = [
      [Math.PI * 2, '2π'], [Math.PI, 'π'], [Math.PI / 2, 'π/2'],
      [Math.PI / 3, 'π/3'], [Math.PI / 4, 'π/4'], [Math.PI / 6, 'π/6'],
      [-Math.PI / 2, '-π/2'], [-Math.PI, '-π'], [-Math.PI / 4, '-π/4'],
    ];
    for (const [v, s] of m) if (Math.abs(a - v) < 0.005) return s;
    return a.toFixed(2);
  }

  function setStatus(msg) { document.getElementById('status').textContent = msg; }

  // ---------- angle modal ----------
  const angleModal = document.getElementById('angle-modal');
  const angleInput = document.getElementById('angle-input');
  function showAngleModal(gate) {
    document.getElementById('angle-title').textContent = `${GATE_NAMES[gate]} — Rotation Angle`;
    angleInput.value = '1.5708';
    angleModal.classList.add('visible');
    setTimeout(() => angleInput.focus(), 0);
  }
  function hideAngleModal() { angleModal.classList.remove('visible'); pendingAngle = null; }

  document.querySelectorAll('.preset-btn').forEach(b => {
    b.addEventListener('click', () => { angleInput.value = b.dataset.val; });
  });
  document.getElementById('angle-ok').addEventListener('click', () => {
    if (!pendingAngle) return hideAngleModal();
    const a = parseFloat(angleInput.value);
    if (!Number.isFinite(a)) return;
    circuit.push({ col: pendingAngle.col, qubit: pendingAngle.qubit, gate: pendingAngle.gate, angle: a });
    hideAngleModal();
    render();
  });
  document.getElementById('angle-cancel').addEventListener('click', hideAngleModal);
  angleInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('angle-ok').click();
    if (e.key === 'Escape') hideAngleModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && pendingCNOT) cancelPendingCNOT();
  });

  // ---------- controls ----------
  document.getElementById('clear-btn').addEventListener('click', () => {
    circuit = [];
    pendingCNOT = null;
    lastResult = null;
    setStatus('');
    document.getElementById('color-section').style.display = 'none';
    renderProbPanel(null);
    render();
  });

  document.getElementById('compute-btn').addEventListener('click', async () => {
    if (pendingCNOT) { setStatus('Finish or cancel the pending CNOT first.'); return; }
    if (circuit.length === 0) { setStatus('Place at least one gate.'); return; }

    const sorted = [...circuit].sort((a, b) => {
      if (a.col !== b.col) return a.col - b.col;
      const qa = a.gate === 'cx' ? Math.min(a.control, a.target) : a.qubit;
      const qb = b.gate === 'cx' ? Math.min(b.control, b.target) : b.qubit;
      return qa - qb;
    });
    const gates = sorted.map(g => {
      if (g.gate === 'cx') return { gate: 'cx', qubits: [g.control, g.target], col: g.col };
      if (ROTATIONS.has(g.gate)) return { gate: g.gate, qubits: [g.qubit], angle: g.angle, col: g.col };
      return { gate: g.gate, qubits: [g.qubit], col: g.col };
    });

    setStatus('Computing…');
    try {
      const res = await fetch('/api/compute', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ num_qubits: NUM_QUBITS, gates }),
      });
      const data = await res.json();
      if (!res.ok) { setStatus('Error: ' + (data.error || 'unknown')); return; }
      setStatus('');
      lastResult = data;
      renderResult(data);
    } catch (e) {
      setStatus('Network error: ' + e.message);
    }
  });

  // ---------- result canvas ----------
  function renderResult(data) {
    renderProbPanel(data.measurements);
    const section = document.getElementById('color-section');
    section.style.display = 'block';
    const canvas = document.getElementById('color-canvas');
    const ctx = canvas.getContext('2d');

    const LABEL_W = 40, SEG_W = 80, WIRE_H = 10, GATE = 30, ROW_H = 56;
    const { num_qubits, num_positions, wire_colors, gates_at_positions } = data;

    canvas.width = LABEL_W + num_positions * SEG_W + 20;
    canvas.height = num_qubits * ROW_H;

    ctx.fillStyle = '#0a0a0a';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Wire segments — segment p goes from x = LABEL_W + p*SEG_W to +(SEG_W)
    for (const wc of wire_colors) {
      const x = LABEL_W + wc.position * SEG_W;
      const y = wc.qubit * ROW_H + ROW_H / 2 - WIRE_H / 2;
      const [r, g, b] = wc.color;
      ctx.fillStyle = `rgb(${Math.round(r * 255)}, ${Math.round(g * 255)}, ${Math.round(b * 255)})`;
      ctx.fillRect(x, y, SEG_W, WIRE_H);
    }

    // Qubit labels
    ctx.fillStyle = '#777';
    ctx.font = '12px "SF Mono", monospace';
    ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
    for (let q = 0; q < num_qubits; q++) {
      ctx.fillText(`q${q}`, LABEL_W - 8, q * ROW_H + ROW_H / 2);
    }

    // Gates — drawn at the LEFT edge of segment p (matches matplotlib draw_color)
    for (const g of gates_at_positions) {
      const gx = LABEL_W + g.position * SEG_W;
      if (g.gate === 'cx') {
        const [ctrl, tgt] = g.qubits;
        const cy = ctrl * ROW_H + ROW_H / 2;
        const ty = tgt * ROW_H + ROW_H / 2;
        ctx.strokeStyle = '#bbb'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.moveTo(gx, cy); ctx.lineTo(gx, ty); ctx.stroke();
        ctx.fillStyle = '#ddd'; ctx.beginPath(); ctx.arc(gx, cy, 5, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#0a0a0a';
        ctx.beginPath(); ctx.arc(gx, ty, 11, 0, Math.PI * 2); ctx.fill();
        ctx.strokeStyle = '#ddd';
        ctx.beginPath(); ctx.arc(gx, ty, 11, 0, Math.PI * 2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(gx - 11, ty); ctx.lineTo(gx + 11, ty); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(gx, ty - 11); ctx.lineTo(gx, ty + 11); ctx.stroke();
      } else {
        const q = g.qubits[0];
        const x = gx - GATE / 2;
        const y = q * ROW_H + ROW_H / 2 - GATE / 2;
        const isMeasure = g.gate === 'measure';
        ctx.fillStyle = isMeasure ? '#1e1824' : '#1a1a1a';
        ctx.strokeStyle = isMeasure ? '#7a5a9a' : '#666';
        ctx.lineWidth = 1;
        ctx.fillRect(x, y, GATE, GATE); ctx.strokeRect(x, y, GATE, GATE);

        ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
        if (g.angle !== undefined) {
          ctx.fillStyle = '#ddd';
          ctx.font = '11px "SF Mono", monospace';
          ctx.fillText(GATE_NAMES[g.gate] || g.gate, gx, y + GATE / 2 - 5);
          ctx.font = '8px "SF Mono", monospace';
          ctx.fillStyle = '#999';
          ctx.fillText(formatAngle(g.angle), gx, y + GATE / 2 + 7);
        } else {
          ctx.fillStyle = isMeasure ? '#b89acc' : '#ddd';
          ctx.font = '12px "SF Mono", monospace';
          ctx.fillText(GATE_NAMES[g.gate] || g.gate, gx, y + GATE / 2);
        }
      }
    }

  }

  function renderProbPanel(measurements) {
    const panel = document.getElementById('prob-panel');
    if (!measurements || measurements.length === 0) {
      panel.classList.add('empty');
      panel.innerHTML = '';
      return;
    }
    panel.classList.remove('empty');
    let html = '<div class="panel-title">Measurements</div>';
    for (const m of measurements) {
      const uiCol = m.position - 1;
      const p0pct = (m.prob_0 * 100).toFixed(1);
      const p1pct = (m.prob_1 * 100).toFixed(1);
      html += `<div class="prob-entry">
        <div class="prob-header"><span>q${m.qubit}</span><span class="pos">col ${uiCol}</span></div>
        <div class="prob-row"><span class="state">|0⟩</span><div class="bar"><div class="fill" style="width:${p0pct}%"></div></div><span class="value">${m.prob_0.toFixed(3)}</span></div>
        <div class="prob-row"><span class="state">|1⟩</span><div class="bar"><div class="fill" style="width:${p1pct}%"></div></div><span class="value">${m.prob_1.toFixed(3)}</span></div>
      </div>`;
    }
    panel.innerHTML = html;
  }

  window.addEventListener('resize', drawCnotLines);

  // ---------- touch drag support ----------
  function slotUnderTouch(touch) {
    const el = document.elementFromPoint(touch.clientX, touch.clientY);
    if (el && el.classList && el.classList.contains('gate-slot')) return el;
    if (el && el.closest) { const s = el.closest('.gate-slot'); if (s) return s; }
    return null;
  }

  document.addEventListener('touchmove', (e) => {
    if (!touchDrag) return;
    const touch = e.touches[0];
    if (!touchMoved) {
      touchMoved = true;
      touchGhost = document.createElement('div');
      touchGhost.className = 'touch-ghost';
      touchGhost.textContent = touchDrag.label;
      document.body.appendChild(touchGhost);
    }
    touchGhost.style.left = (touch.clientX - 20) + 'px';
    touchGhost.style.top = (touch.clientY - 20) + 'px';
    document.querySelectorAll('.gate-slot.drag-over').forEach(s => s.classList.remove('drag-over'));
    const slot = slotUnderTouch(touch);
    if (slot) slot.classList.add('drag-over');
    e.preventDefault();
  }, { passive: false });

  document.addEventListener('touchend', (e) => {
    if (!touchDrag) return;
    if (touchGhost) { touchGhost.remove(); touchGhost = null; }
    document.querySelectorAll('.gate-slot.drag-over').forEach(s => s.classList.remove('drag-over'));

    if (!touchMoved) { touchDrag = null; return; }  // short tap — let click fire

    suppressClick = true;
    setTimeout(() => { suppressClick = false; }, 300);

    const touch = e.changedTouches[0];
    const slot = slotUnderTouch(touch);
    if (slot) {
      const dropCol = +slot.dataset.col;
      const dropQubit = +slot.dataset.qubit;
      if (touchDrag.source === 'palette') {
        dragGate = touchDrag.gate;
        handleDrop(dropCol, dropQubit);
      } else if (touchDrag.source === 'placed') {
        dragPlaced = { gateRef: touchDrag.gateRef, role: touchDrag.role };
        handleDrop(dropCol, dropQubit);
      }
    }
    touchDrag = null;
  });

  render();
</script>
</body>
</html>
